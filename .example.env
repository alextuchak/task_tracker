# app (version and env arrive from the release tag / environment)
ENV=develop
APP_VERSION=dev
CONFIG_PATH=/config.yaml

# mysql server bootstrap
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=tasks
MYSQL_USER=tasks
MYSQL_PASSWORD=tasks

# migrator
GOOSE_DRIVER=mysql
GOOSE_DBSTRING=tasks:tasks@tcp(mysql:3306)/tasks?parseTime=true
