                            "$ref": "#/definitions/internal_transport_http_auth.loginResponse"
                        }
                    },
                    "400": {
                        "description": "невалидный json",
                        "schema": {
                            "$ref": "#/definitions/task_tracker_internal_transport_http_httpkit.ErrorResponse"
                        }
                    },
                    "401": {
                        "description": "неверные креды",
                        "schema": {
                            "$ref": "#/definitions/task_tracker_internal_transport_http_httpkit.ErrorResponse"
                        }
                    }
                }
            }
        },
